# Telegram Bot Token (obligatorio) - lo obtienes de @BotFather en Telegram
BOT_TOKEN=tu_token_aqui

# Secreto para verificar webhooks de GitHub (opcional pero recomendado)
# Lo configuras en Settings → Webhooks de tu repo en GitHub
WEBHOOK_SECRET=tu_secreto_github

# Puerto donde correrá el servidor webhook (default: 8080)
WEBHOOK_PORT=8080

# Ruta del archivo SQLite (default: data.sqlite)
DATABASE_PATH=data.sqlite
